{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MySQL Sample Export",
  "version": "1.0.3",
  "identifier": "com.rurubudong1211.mysqlsampleexport",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MySQL Sample Export",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "template": "wix/per-user-main.wxs",
        "language": {
          "zh-CN": {
            "localePath": "wix/zh-CN.wxl"
          }
        }
      },
      "nsis": {
        "languages": [
          "SimpChinese"
        ]
      }
    }
  }
}

